# ── Postgres ─────────────────────────────────────────────
POSTGRES_DB=kanban
POSTGRES_USER=kanban
POSTGRES_PASSWORD=kanban
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Django ───────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production-please-really
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Origins, которым разрешён CORS/CSRF (фронтенд Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Channels layer ───────────────────────────────────────
# Пусто = in-memory-шина (для одного процесса backend, MVP-режим).
# Задай URL и подними сервис redis, только когда масштабируешь backend.
REDIS_URL=

# ── Frontend ─────────────────────────────────────────────
# Куда фронтенд стучится за REST и WS (браузер, поэтому localhost)
VITE_API_BASE=http://localhost:8000
VITE_WS_BASE=ws://localhost:8000
