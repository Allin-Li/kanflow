# Прод-окружение. Скопируйте на сервер как /opt/kanflow/.env и подставьте
# реальные секреты. Этот файл в git — только образец, без секретов.

# ── Postgres ─────────────────────────────────────────────
POSTGRES_DB=kanflow
POSTGRES_USER=kanflow
POSTGRES_PASSWORD=CHANGE-ME-strong-random-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Django ───────────────────────────────────────────────
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE-ME-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=kanflow.allinli.ru
# Нужно для CSRF в Django admin по HTTPS (WS-валидатор берёт host из ALLOWED_HOSTS).
CORS_ALLOWED_ORIGINS=https://kanflow.allinli.ru

# ── Channels ─────────────────────────────────────────────
# Пусто = in-memory-шина (хватает для одного процесса backend).
REDIS_URL=
